<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    >

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <Button
                android:id="@+id/button_downloaded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="List of Downloaded"
                android:layout_margin="16dp"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >
                <Button
                    android:id="@+id/button_download"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Download"
                    android:layout_margin="16dp"
                    />
                <TextView
                    android:id="@+id/text_download_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    />
                <Button
                    android:id="@+id/button_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel / delete"
                    android:layout_margin="16dp"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >
                <Button
                    android:id="@+id/button_token"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use authorization token"
                    android:layout_margin="16dp"
                    />
                <EditText
                    android:id="@+id/input_token"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="JWT BASE64"
                    android:layout_marginTop="16dp"
                    />
            </LinearLayout>

            <Button
                android:id="@+id/button_logs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get logs"
                android:layout_margin="16dp"
                />

        </LinearLayout>

    </ScrollView>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        />
</FrameLayout>
