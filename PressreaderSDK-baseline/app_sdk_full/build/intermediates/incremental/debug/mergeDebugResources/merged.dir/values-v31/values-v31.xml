<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Pressreader.Base" parent="Theme.MaterialComponents.NoActionBar.Bridge">
        
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorNavBarPrimary" type="color">@color/navigation_bar</item>
        <item name="colorAccent">@color/colorPrimary</item>
        <item name="android:windowSoftInputMode">adjustNothing</item>
        
        <item name="android:windowBackground">@color/pressreader_windowBackground_dark</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="alertDialogTheme">@style/Theme.Pressreader.Light.Dialog.Alert</item>
        <item name="bottomSheetDialogTheme">@style/Theme.Pressreader.Dark.BottomSheetDialog</item>
        <item name="secondaryWindowBackground" type="color">
            @color/pressreader_windowBackground_secondary_dark
        </item>
        <item name="colorTintPrimary" type="color">@color/white</item>
        <item name="publication_filterbutton_background" type="drawable">
            @drawable/filter_button_bg_dark
        </item>
        <item name="listItemDecatorColor" type="color">#16FFFFFF</item>
        <item name="drawable_collections_popup_bg">@color/fragment_bg</item>
        <item name="materialButtonStyle">@style/RoundedMaterialButton</item>
        <item name="borderlessButtonStyle">@style/RoundedTextMaterialButton</item>

        <item name="feedBackground">@color/pressreader_feed_background</item>
        <item name="feedBackground60">@color/pressreader_feed_background60</item>
        <item name="feedCardBackground">@color/pressreader_feed_card_background</item>
        <item name="feedCardTitleTextColor">@color/feed_title</item>
        <item name="articleBodyTextColor">@color/article_body_text</item>
        <item name="articleTitleTextColor">@color/article_body_text</item>
        <item name="feedCardSourceTextColor">@color/feed_title</item>
        <item name="feedCardDescriptionTextColor">@color/feed_description</item>
        <item name="feedCardSimilarStoriesStroke">@color/feed_similar_stories_color_stroke_outer</item>
        <item name="feedRelatedStoriesTextColor">@color/feed_description</item>
        <item name="feedSeparatorColor">@color/feed_separator</item>
        <item name="feedCardBackgroundArticle">@color/pressreader_article_details_background</item>
        <item name="feedCardBackgroundComments">@color/pressreader_comments_background</item>
        <item name="feedCardBackgroundCommentNeutral">@color/pressreader_comment_neutral_background</item>
        <item name="feedCardBackgroundCommentPositive">@color/pressreader_comment_positive_background</item>
        <item name="feedCardBackgroundCommentNegative">@color/pressreader_comment_negative_background</item>
        <item name="feedCommentTextColor">@color/pressreader_comment_text_color</item>
        <item name="feedCommentActionIconColor">@color/black</item>

        <item name="navigationIconColor">@color/primary_dark</item>

        <item name="windowActionModeOverlay">true</item>
        <item name="actionModeStyle">@style/Theme.Pressreader.ActionModeStyle</item>

        <item name="feedInterestCardTextColor">@color/feed_title</item>
        <item name="feedInterestCardBackground">@color/grey_17</item>

        <item name="android:windowSplashScreenBackground">@color/color_background_dark</item>
    </style>
    <style name="Theme.SplashScreen" parent="Base.Theme.SplashScreen.DayNight">
        <item name="android:windowSplashScreenAnimatedIcon">?windowSplashScreenAnimatedIcon</item>
        <item name="android:windowSplashScreenBackground">?windowSplashScreenBackground</item>
        <item name="android:windowSplashScreenAnimationDuration">
            ?windowSplashScreenAnimationDuration
        </item>
    </style>
    <style name="Theme.SplashScreen.IconBackground" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenIconBackgroundColor">
            ?windowSplashScreenIconBackgroundColor
        </item>
    </style>
</resources>